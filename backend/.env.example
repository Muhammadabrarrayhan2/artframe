# App
APP_NAME=ArtFrame
DEBUG=True
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Database
DATABASE_URL=sqlite+aiosqlite:///./artframe.db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ORIGIN_REGEX=

# Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=25

# OTP
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Email (for dev, OTPs are printed to console)
EMAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@artframe.local
EMAIL_FROM_NAME=ArtFrame
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# Voice conversion provider
# Use local for built-in DSP fallback, or set to a provider name such as rvc
VOICE_CONVERSION_PROVIDER=local
VOICE_CONVERSION_ENDPOINT=
VOICE_CONVERSION_TOKEN=
VOICE_CONVERSION_TIMEOUT_SECONDS=120
VOICE_MODEL_MALE_TO_FEMALE=
VOICE_MODEL_FEMALE_TO_MALE=
VOICE_MODEL_YOUNGER=
VOICE_MODEL_OLDER=
